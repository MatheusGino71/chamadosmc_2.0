[debug] [2026-04-08T13:14:48.653Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/chamadosmeucurso/rulesets {"name":"projects/chamadosmeucurso/rulesets/66b7026b-7c75-459c-a400-4fcc52512532","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    // Regras específicas para Configurações de Formulários por Setor\r\n    match /formConfigs/{setor} {\r\n      // Qualquer usuário autenticado pode ler FormConfigs\r\n      allow read: if request.auth != null;\r\n      \r\n      // Apenas admin_ti ou admin do setor específico podem escrever\r\n      allow write: if request.auth != null && (\r\n        request.auth.token.role == 'admin_ti' ||\r\n        request.auth.token.role == 'admin_' + setor.replace('setor_', '').replace(/_/g, ' ').toLowerCase()\r\n      );\r\n      \r\n      // Apenas admin_ti podem deletar\r\n      allow delete: if request.auth != null && request.auth.token.role == 'admin_ti';\r\n    }\r\n\r\n    // Qualquer coleção e subcoleção (fallback)\r\n    match /{document=**} {\r\n      // Usuários autenticados podem ler tudo\r\n      allow read: if request.auth != null;\r\n      \r\n      // Usuários autenticados podem criar tudo\r\n      allow create: if request.auth != null;\r\n      \r\n      // Usuários autenticados podem atualizar tudo\r\n      allow update: if request.auth != null;\r\n      \r\n      // Usuários autenticados podem deletar tudo\r\n      allow delete: if request.auth != null;\r\n    }\r\n  }\r\n}","name":"firestore.rules"}]},"createTime":"2026-04-08T13:14:48.519535Z","metadata":{"services":["cloud.firestore"]}}
