rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para tickets
    match /tickets/{ticketId} {
      // Usuários autenticados podem ler todos os tickets
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar tickets
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
      
      // Admins podem atualizar qualquer ticket
      // Usuários podem atualizar apenas seus próprios tickets
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.userId == request.auth.uid
      );
      
      // Admins ou o próprio dono do ticket podem deletar
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.userId == request.auth.uid
      );
    }
    
    // Regras para mensagens de chat (subcoleção)
    match /tickets/{ticketId}/messages/{messageId} {
      // Usuários autenticados podem ler mensagens dos tickets que têm acesso
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar mensagens
      allow create: if request.auth != null;
      
      // Usuários podem atualizar suas próprias mensagens
      allow update: if request.auth != null && resource.data.senderId == request.auth.uid;
      
      // Admins ou o dono do ticket podem deletar mensagens
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid
      );
    }
    
    // Regras para usuários
    match /users/{userId} {
      // Usuários autenticados podem ler qualquer perfil (necessário para verificar roles)
      allow read: if request.auth != null;
      
      // Usuários podem criar seu próprio perfil
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Usuários podem atualizar seu próprio perfil
      // Admins podem atualizar qualquer usuário
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Apenas admins podem deletar usuários
      allow delete: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}