rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para chamados
    match /chamados/{chamadoId} {
      // Usuários autenticados podem ler seus próprios chamados
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar chamados
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
      
      // Admins podem atualizar qualquer chamado
      // Usuários podem atualizar apenas seus próprios chamados
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.userId == request.auth.uid
      );
      
      // Apenas admins podem deletar
      allow delete: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Regras para mensagens de chat
    match /chamados/{chamadoId}/messages/{messageId} {
      // Usuários autenticados podem ler mensagens dos chamados que têm acesso
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar mensagens
      allow create: if request.auth != null;
    }
    
    // Regras para usuários
    match /users/{userId} {
      // Usuários podem ler seu próprio perfil
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Usuários podem criar seu próprio perfil
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Usuários podem atualizar seu próprio perfil
      allow update: if request.auth != null && request.auth.uid == userId;
    }
  }
}