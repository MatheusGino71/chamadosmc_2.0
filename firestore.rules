rules_version = '2';

service cloud.firestore {
  // Função auxiliar para verificar se um role é admin
  function isAdmin(role) {
    return role == 'admin' || role.matches('admin_.*');
  }
  
  // Função para obter o role do usuário
  function getUserRole() {
    return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
  }

  match /databases/{database}/documents {
    // Regras para tickets
    match /tickets/{ticketId} {
      // Usuários autenticados podem ler todos os tickets
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar tickets
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
      
      // Admins podem atualizar qualquer ticket
      // Usuários podem atualizar apenas seus próprios tickets
      allow update: if request.auth != null && (
        isAdmin(getUserRole()) ||
        resource.data.userId == request.auth.uid
      );
      
      // Admins ou o próprio dono do ticket podem deletar
      allow delete: if request.auth != null && (
        isAdmin(getUserRole()) ||
        resource.data.userId == request.auth.uid
      );
    }
    
    // Regras para mensagens de chat (subcoleção)
    match /tickets/{ticketId}/messages/{messageId} {
      // Usuários autenticados podem ler mensagens dos tickets que têm acesso
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar mensagens
      allow create: if request.auth != null;
      
      // Usuários podem atualizar suas próprias mensagens
      allow update: if request.auth != null && resource.data.senderId == request.auth.uid;
      
      // Admins ou o dono do ticket podem deletar mensagens
      allow delete: if request.auth != null && (
        isAdmin(getUserRole()) ||
        get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid
      );
    }
    
    // Regras para mensagens internas (subcoleção - apenas admins)
    match /tickets/{ticketId}/internalMessages/{messageId} {
      // Apenas admins podem ler mensagens internas
      allow read: if request.auth != null && 
                     isAdmin(getUserRole());
      
      // Apenas admins podem criar mensagens internas
      allow create: if request.auth != null && 
                      isAdmin(getUserRole());
      
      // Admins podem atualizar suas próprias mensagens internas
      allow update: if request.auth != null && 
                      isAdmin(getUserRole()) &&
                      resource.data.senderId == request.auth.uid;
      
      // Apenas admins podem deletar mensagens internas
      allow delete: if request.auth != null && 
                      isAdmin(getUserRole());
    }
    
    // Regras para usuários
    match /users/{userId} {
      // Usuários autenticados podem ler qualquer perfil (necessário para verificar roles)
      allow read: if request.auth != null;
      
      // Usuários podem criar seu próprio perfil
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Usuários podem atualizar seu próprio perfil
      // Admins podem atualizar qualquer usuário
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin(getUserRole())
      );
      
      // Apenas admins podem deletar usuários
      allow delete: if request.auth != null && 
                      isAdmin(getUserRole());
    }
    
    // Regras para contadores de IDs (garantir IDs únicos)
    match /counters/{counterId} {
      // Usuários autenticados podem ler contadores
      allow read: if request.auth != null;
      
      // Apenas usuários autenticados podem criar/atualizar contadores (via transação)
      allow create, update: if request.auth != null;
      
      // Apenas admins podem deletar contadores
      allow delete: if request.auth != null && 
                      isAdmin(getUserRole());
    }
    
    // Regras para notificações
    match /notifications/{notificationId} {
      // Usuários podem ler suas próprias notificações
      allow read: if request.auth != null;
      
      // Qualquer usuário autenticado pode criar notificações
      allow create: if request.auth != null &&
                      request.resource.data.recipientId != null;
      
      // Usuários podem atualizar apenas suas próprias notificações (para marcar como lida)
      allow update: if request.auth != null && 
                      resource.data.recipientId == request.auth.uid;
      
      // Usuários podem deletar suas próprias notificações
      allow delete: if request.auth != null && 
                      resource.data.recipientId == request.auth.uid;
    }
    
    // Regras para mensagens entre administradores
    match /adminMessages/{messageId} {
      // Admins podem ler mensagens
      allow read: if request.auth != null && 
                     isAdmin(getUserRole());
      
      // Apenas admins podem criar mensagens
      allow create: if request.auth != null && 
                      isAdmin(getUserRole()) &&
                      request.resource.data.senderId == request.auth.uid;
      
      // Apenas admins podem atualizar mensagens
      allow update: if request.auth != null && 
                      isAdmin(getUserRole());
      
      // Remetente e destinatário podem deletar
      allow delete: if request.auth != null && 
                      isAdmin(getUserRole());
    }
  }
}