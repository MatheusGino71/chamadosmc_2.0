rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Regras para tickets (imagens e documentos)
    match /tickets/{allPaths=**} {
      // Permite leitura e escrita para usuários autenticados
      allow read, write: if request.auth != null;
    }
    
    // Mantém regras antigas para compatibilidade
    match /chamados/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
