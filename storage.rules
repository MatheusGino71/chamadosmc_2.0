rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Regras para imagens de chamados
    match /tickets/images/{fileName} {
      // Qualquer usuário autenticado pode fazer upload
      allow create: if request.auth != null &&
                      request.resource.size < 10 * 1024 * 1024 && // Máximo 10MB
                      request.resource.contentType.matches('image/.*');
      
      // Qualquer usuário autenticado pode ler
      allow read: if request.auth != null;
      
      // Apenas admins podem deletar
      allow delete: if request.auth != null &&
                      firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Regras para documentos de chamados
    match /tickets/documents/{fileName} {
      // Qualquer usuário autenticado pode fazer upload
      allow create: if request.auth != null &&
                      request.resource.size < 10 * 1024 * 1024 && // Máximo 10MB
                      (request.resource.contentType.matches('application/pdf') ||
                       request.resource.contentType.matches('application/msword') ||
                       request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*') ||
                       request.resource.contentType.matches('application/vnd.ms-excel') ||
                       request.resource.contentType.matches('text/plain'));
      
      // Qualquer usuário autenticado pode ler
      allow read: if request.auth != null;
      
      // Apenas admins podem deletar
      allow delete: if request.auth != null &&
                      firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Mantém regras antigas para compatibilidade
    match /chamados/{userId}/{fileName} {
      // Qualquer usuário autenticado pode fazer upload
      allow create: if request.auth != null &&
                      request.resource.size < 5 * 1024 * 1024 && // Máximo 5MB
                      request.resource.contentType.matches('image/.*');
      
      // Qualquer usuário autenticado pode ler
      allow read: if request.auth != null;
      
      // Apenas o dono ou admin pode deletar
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
